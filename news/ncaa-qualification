                    <td class="td-status status-x">LOCK (X)</td>
                </tr>
                <tr>
                    <td>Sydney Bergstrom (Penn)</td>
                    <td>1650 Free</td>
                    <td>16:09.74</td>
                    <td class="td-status status-x">LOCK (X)</td>
                </tr>
                <tr>
                    <td>Kiley Wilhelm (Harvard)</td>
                    <td>100 Fly</td>
                    <td>51.78</td>
                    <td class="td-status status-x">LOCK (X)</td>
                </tr>
            </tbody>
        </table>
    </div>

     <div class="table-wrap animate-load delay-5">
        <h3 style="padding: 20px 25px 0; font-size: 16px;">The Bubble Watch (Category Y)</h3>
        <table>
            <thead>
                <tr>
                    <th>Атлет</th>
                    <th>Дисциплина</th>
                    <th>Время</th>
                    <th>Gap to Cut</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Payton Kelly (Ball St)</td>
                    <td>50 Free</td>
                    <td>22.24</td>
                    <td class="td-status status-y">-0.04s</td>
                </tr>
                 <tr>
                    <td>Tess Whineray (Col St)</td>
